# ── Database Connection ──
DATABASE_URL=postgresql://user:password@localhost:5432/leadhouse

# ── Admin Account ──
ADMIN_EMAIL=admin@leadmachine.ai
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# ── Claude API (for AI Scoring & AI Assistant) ──
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ── Google Maps API (for lead scraping) ──
# Get your key: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# ── Razorpay Payment Gateway ──
# Step 1: Sign up at https://dashboard.razorpay.com/signup
# Step 2: Complete KYC verification
# Step 3: Go to Settings → API Keys → Generate Key
# Step 4: Copy Key ID and Key Secret below
#
# For TESTING: Use Razorpay Test Mode keys (starts with rzp_test_)
# For PRODUCTION: Use Live Mode keys (starts with rzp_live_)
#
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend Email Service (for outreach) ──
# Step 1: Sign up at https://resend.com
# Step 2: Go to Domains → Add your sending domain
# Step 3: Add the DNS records (SPF, DKIM) Resend gives you
# Step 4: Go to API Keys → Create API Key
#
# Free tier: 100 emails/day, 3,000/month
# Pro ($20/mo): 50,000 emails/month
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=hello@yourdomain.com
FROM_NAME=LeadHouse
DAILY_EMAIL_LIMIT=30

# ── Base URL (your deployed domain) ──
BASE_URL=http://localhost:3000

# ── Secret Key (for JWT tokens — auto-generated if empty) ──
SECRET_KEY=
